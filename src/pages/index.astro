---
import Layout from '../layouts/Layout.astro';
import Clock from '../components/Clock.astro'; 
import WindowManager from '../components/WindowManager.jsx';
import TopControls from '../components/TopControls.astro';
import LanguageToggle from '../components/LanguageToggle.astro';

import FallingSakura from '../components/FallingSakura.jsx';
import Icons from '../components/Icons.astro';

const country = Astro.request.headers.get('x-vercel-ip-country') || 'US';
const initialLang = country === 'JP' ? 'ja' : 'en';
---

<Layout title="Sandeep | Portfolio">
  
  <main class="h-screen w-screen overflow-hidden relative bg-[#c9d4d9] dark:bg-[#2d3238] transition-colors duration-500 p-4 flex flex-col justify-center items-center">
    
    <main id="desktop-environment" data-ip-lang={initialLang} class="h-screen w-screen overflow-hidden relative bg-[#c9d4d9] dark:bg-[#2d3238] transition-colors duration-500 p-4 flex flex-col justify-center items-center"></main>

    <FallingSakura client:load />

    <TopControls />
    <LanguageToggle />
    <WindowManager client:only="react" />

    <h1 class="text-5xl md:text-6xl font-bold text-[#5c4f4f] dark:text-[#e4dcc6] transition-colors duration-500 mb-8 tracking-widest pointer-events-none drop-shadow-sm select-none relative z-10">
      <span class="lang-swap" data-en="Hi, I'm " data-ja="こんにちは、">Hi, I'm </span>
      <span class="text-[#d48c70] drop-shadow-md lang-swap" data-en="Sandeep!" data-ja="サンディープです！">Sandeep!</span>
    </h1>

    <Clock />

    <div class="relative z-10 flex flex-row justify-center gap-4 md:gap-10 w-full md:w-fit pointer-events-auto mt-4 px-2">
      
      <Icons id="about" title="About Me" titleJa="自己紹介">
        <svg slot="icon" viewBox="0 0 24 24" fill="currentColor" class="w-full h-full pixel-art">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
      </Icons>

      <Icons id="projects" title="Projects" titleJa="プロジェクト">
        <svg slot="icon" viewBox="0 0 24 24" fill="currentColor" class="w-full h-full pixel-art">
          <path d="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>
        </svg>
      </Icons>

      <Icons id="contact" title="Contact" titleJa="連絡先">
        <svg slot="icon" viewBox="0 0 24 24" fill="currentColor" class="w-full h-full pixel-art">
          <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </Icons>

      <Icons id="credits" title="Credits" titleJa="クレジット">
        <svg slot="icon" viewBox="0 0 24 24" fill="currentColor" class="w-full h-full pixel-art">
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z"/>
        </svg>
      </Icons>

    </div>

    <div class="absolute bottom-4 text-sm font-bold text-[#8f9ca6] dark:text-[#e4dcc6] dark:opacity-50 transition-colors duration-500 pointer-events-none drop-shadow-sm select-none text-center w-full">
      © {new Date().getFullYear()} <span class="lang-swap" data-en="Sandeep Ganesan" data-ja="サンディープ　ガネーサン">Sandeep Ganesan</span>
    </div>

  </main>
</Layout>

<script>
  import { currentLang } from '../store/locale.js';

  const translatableElements = document.querySelectorAll('.lang-swap');

  currentLang.subscribe((lang) => {
    translatableElements.forEach((el) => {
      if (el instanceof HTMLElement) {
        el.textContent = lang === 'en' ? el.dataset.en : el.dataset.ja;
      }
    });
  });
</script>