---
// src/components/Clock.astro
---
<div 
  id="desktop-clock" 
  class="text-7xl md:text-9xl font-bold text-[#5c4f4f] dark:text-[#e4dcc6] mb-8 cursor-pointer hover:text-[#d97373] dark:hover:text-[#d97373] transition-colors select-none drop-shadow-sm tracking-widest text-center pointer-events-auto"
>
  --:--
</div>

<script>
  import { openWindow } from '../store/windows.js';
  import { currentLang } from '../store/locale.js';

  const clockEl = document.getElementById('desktop-clock');
  let currentLocale = 'en-US';
  
  function updateClock() {
    if (!clockEl) return;
    const now = new Date();
    
    const formatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'Asia/Tokyo',
      hour: 'numeric',
      minute: '2-digit',
      hour12: false
    });
    
    const timeParts = formatter.format(now).split(':');
    const hour24 = parseInt(timeParts[0], 10);
    const minute = timeParts[1];

    const isPM = hour24 >= 12;
    let hour12 = hour24 % 12;
    if (hour12 === 0) hour12 = 12; // Handles midnight and noon

    if (currentLocale === 'ja-JP') {
      const ampm = isPM ? '午後' : '午前';
      clockEl.textContent = `${ampm}${hour12}時${minute}分`;
    } else {
      const ampmEn = isPM ? 'PM' : 'AM';
      const paddedHour = hour12.toString().padStart(2, '0');
      clockEl.textContent = `${paddedHour}:${minute} ${ampmEn}`;
    }
  }
  
  currentLang.subscribe((lang) => {
    currentLocale = lang === 'en' ? 'en-US' : 'ja-JP';
    updateClock(); 
  });
  
  setInterval(updateClock, 1000);

  clockEl?.addEventListener('click', () => {
    openWindow('clock', 'Time.txt');
  });
</script>