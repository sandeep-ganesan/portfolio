---
// src/components/TopControls.astro
---
<div class="fixed top-6 left-6 z-50 flex gap-4 pointer-events-auto">
  

  <button 
    id="music-toggle" 
    class="w-12 h-12 bg-[#f4ece6] border-4 border-[#5c4f4f] flex items-center justify-center hover:-translate-y-1 transition-transform shadow-[4px_4px_0px_0px_rgba(92,79,79,0.3)] dark:bg-[#3e464f] dark:border-[#1a1e24] text-[#5c4f4f] dark:text-[#e4dcc6]"
    aria-label="Toggle Music"
  >

    <svg id="icon-play" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 block">
      <path d="M8 5v14l11-7z"/>
    </svg>

    <svg id="icon-mute" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 hidden">
      <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
    </svg>
  </button>


  <button 
    id="theme-toggle" 
    class="w-12 h-12 bg-[#f4ece6] border-4 border-[#5c4f4f] flex items-center justify-center hover:-translate-y-1 transition-transform shadow-[4px_4px_0px_0px_rgba(92,79,79,0.3)] dark:bg-[#3e464f] dark:border-[#1a1e24] text-[#5c4f4f] dark:text-[#e4dcc6]"
    aria-label="Toggle Theme"
  >

    <svg id="icon-sun" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 hidden">
      <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
    </svg>

    <svg id="icon-moon" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 block">
      <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
    </svg>
  </button>

  <audio id="bg-music" loop>
    <source src="/media/Gymnopedie-no-1.mp3" type="audio/mpeg">
  </audio>
</div>

<script>
  // --- MUSIC LOGIC ---
  const musicBtn = document.getElementById('music-toggle');
  const iconPlay = document.getElementById('icon-play');
  const iconMute = document.getElementById('icon-mute');
  const audio = document.getElementById('bg-music') as HTMLAudioElement;
  
  if (audio) {
    audio.volume = 0.5;
    audio.loop = true;
  }
  let isPlaying = false;

  musicBtn?.addEventListener('click', () => {
    if (isPlaying && audio && iconPlay && iconMute) {
      audio.pause();
      iconPlay.classList.remove('hidden');
      iconPlay.classList.add('block');
      iconMute.classList.add('hidden');
      iconMute.classList.remove('block');
    } else if (audio && iconPlay && iconMute) {
      audio.play();
      iconPlay.classList.add('hidden');
      iconPlay.classList.remove('block');
      iconMute.classList.remove('hidden');
      iconMute.classList.add('block');
    }
    isPlaying = !isPlaying;
  });

  // --- DARK MODE LOGIC ---
  const themeBtn = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');
  const htmlEl = document.documentElement;

  const savedTheme = localStorage.getItem('theme');
  
  if (savedTheme === 'light' || !savedTheme) {
    if (iconSun && iconMoon) {
      iconSun.classList.add('hidden');
      iconSun.classList.remove('block');
      iconMoon.classList.add('block');
      iconMoon.classList.remove('hidden');
    }
  } else {
    if (iconSun && iconMoon) {
      iconSun.classList.remove('hidden');
      iconSun.classList.add('block');
      iconMoon.classList.remove('block');
      iconMoon.classList.add('hidden');
    }
  }

  themeBtn?.addEventListener('click', () => {
    htmlEl.classList.toggle('dark');
    const isDark = htmlEl.classList.contains('dark');

    if (isDark) {
      localStorage.setItem('theme', 'dark');
      if (iconSun && iconMoon) {
        iconSun.classList.remove('hidden');
        iconSun.classList.add('block');
        iconMoon.classList.remove('block');
        iconMoon.classList.add('hidden');
      }
    } else {
      localStorage.setItem('theme', 'light');
      if (iconSun && iconMoon) {
        iconSun.classList.add('hidden');
        iconSun.classList.remove('block');
        iconMoon.classList.add('block');
        iconMoon.classList.remove('hidden');
      }
    }
  });
</script>